{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LogBrew",
  "description": "LogBrew documentation. A mobile-first iOS app that brings errors, deployments, SLA alerts, and payment failures from Sentry, Vercel, Railway, PostHog, Linear, and Stripe into one real-time feed.",
  "colors": {
    "primary": "#30D158",
    "light": "#34C759",
    "dark": "#30D158"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://logbrew.co"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guide",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "icon": "compass",
            "pages": [
              "concepts/feed-and-events",
              "concepts/logs",
              "concepts/projects",
              "concepts/notifications"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/overview",
              "integrations/sentry",
              "integrations/vercel",
              "integrations/railway",
              "integrations/posthog",
              "integrations/linear",
              "integrations/stripe",
              "integrations/request"
            ]
          },
          {
            "group": "Features",
            "icon": "sparkles",
            "pages": [
              "features/live-feed",
              "features/resolve-sync",
              "features/sharing",
              "features/saved-filters"
            ]
          },
          {
            "group": "Account & Settings",
            "icon": "settings",
            "pages": ["settings/account", "settings/notifications"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/LogBrewCo"
    }
  },
  "css": "/custom.css",
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "og:site_name": "LogBrew Docs",
    "og:type": "website",
    "og:description": "Documentation for LogBrew, the mobile-first iOS app that brings errors, deployments, SLA alerts, and payment failures into one real-time feed.",
    "twitter:card": "summary_large_image"
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "perplexity", "cursor", "vscode"]
  }
}
