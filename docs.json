{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LogBrew",
  "description": "Agent-first observability for developers. Read logs, traces, issues, actions, and releases from the native LogBrew CLI and API.",
  "colors": {
    "primary": "#065F46",
    "light": "#34D399",
    "dark": "#047857"
  },
  "logo": {
    "light": "/logo/logbrew-logo-transparent.svg",
    "dark": "/logo/logbrew-logo-transparent.svg",
    "href": "https://logbrew.co"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://logbrew.co"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/LogBrewCo"
      }
    ]
  },
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "icon": "rocket",
        "pages": ["introduction", "quickstart"]
      },
      {
        "group": "Concepts",
        "icon": "compass",
        "pages": [
          "concepts/telemetry",
          "concepts/releases",
          "concepts/projects",
          "concepts/mobile-app"
        ]
      },
      {
        "group": "Guides",
        "icon": "square-terminal",
        "pages": [
          "guides/cli",
          "guides/ai-agents",
          "guides/troubleshooting",
          "guides/sdk-ingestion",
          "guides/issue-workflow"
        ]
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "pages": [
          "reference/cli",
          "reference/telemetry-api",
          "reference/telemetry-data"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/LogBrewCo"
    }
  },
  "metadata": {
    "og:site_name": "LogBrew Docs",
    "og:type": "website",
    "og:description": "Docs for LogBrew, the agent-first observability CLI and API for logs, traces, issues, actions, and releases.",
    "twitter:card": "summary_large_image"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "redirects": [
    {
      "source": "/concepts/feed-and-events",
      "destination": "/concepts/telemetry"
    },
    {
      "source": "/concepts/logs",
      "destination": "/concepts/telemetry"
    },
    {
      "source": "/concepts/notifications",
      "destination": "/concepts/mobile-app"
    },
    {
      "source": "/features/live-feed",
      "destination": "/concepts/mobile-app"
    },
    {
      "source": "/features/resolve-sync",
      "destination": "/guides/issue-workflow"
    },
    {
      "source": "/features/saved-filters",
      "destination": "/guides/cli"
    },
    {
      "source": "/features/sharing",
      "destination": "/guides/issue-workflow"
    },
    {
      "source": "/integrations/overview",
      "destination": "/guides/sdk-ingestion"
    },
    {
      "source": "/integrations/:provider",
      "destination": "/guides/sdk-ingestion"
    },
    {
      "source": "/settings/account",
      "destination": "/quickstart"
    },
    {
      "source": "/settings/notifications",
      "destination": "/concepts/mobile-app"
    }
  ],
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  }
}
